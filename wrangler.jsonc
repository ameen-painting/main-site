{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "main-site",
  "main": "index.js",
  "compatibility_date": "2026-07-11",
  "keep_vars": true,
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ameen-painting-bookings",
      "database_id": "e955ac99-5bf2-40f2-b7a0-c5921c696640"
    }
  ]
}
